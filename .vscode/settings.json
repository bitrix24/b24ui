{
  "editor.quickSuggestions": {
    "strings": "on"
  },
  "editor.codeActionsOnSave": {
    "source.fixAll": "never",
    "source.fixAll.eslint": "explicit"
  },
  "files.associations": {
    "*.css": "tailwindcss"
  },
  "prettier.enable": false,
  "tailwindCSS.classAttributes": ["class", "b24ui"],
  "tailwindCSS.experimental.classRegex": [
    ["['\"`]([^'\"`]*)['\"`]"]
  ],
  "tailwindCSS.experimental.configFile": {
    "playgrounds/nuxt/app/assets/css/main.css": ["playgrounds/nuxt/**", "src/**"],
    "playgrounds/vue/src/assets/css/main.css": "playgrounds/vue/**",
    "playgrounds/demo/app/assets/css/main.css": "playgrounds/demo/**",
    "docs/app/assets/css/main.css": "docs/**"
  }
}
